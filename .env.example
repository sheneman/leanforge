# ============================================================
# forge-lean-prover environment configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# --- External API keys -------------------------------------------
BRAVE_API_KEY=              # Brave Search MCP server
NEMOTRON_API_KEY=           # Nemotron-3-Super-120B orchestrator
NEMOTRON_API_BASE=          # e.g. https://integrate.api.nvidia.com/v1
LEANSTRAL_API_KEY=          # Leanstral proof-synthesis model
LEANSTRAL_API_BASE=         # e.g. https://integrate.api.nvidia.com/v1

# --- Service URLs ------------------------------------------------
# Set these to your deployed service endpoints.
# If running locally, use http://localhost:XXXX
# If deployed on a server behind nginx, use https://your-host/service-prefix
ORCHESTRATOR_URL=http://localhost:8100
LEAN_ENV_URL=http://localhost:8101
PROOF_SEARCH_URL=http://localhost:8102
RETRIEVAL_URL=http://localhost:8103
TELEMETRY_URL=http://localhost:8104

# --- Logging & tuning --------------------------------------------
LOG_LEVEL=info
BRANCH_BUDGET=50
PROOF_TIMEOUT_SECS=120
