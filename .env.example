# ============================================================
# forge-lean-prover environment configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# --- LLM Provider (any OpenAI-compatible API) ----------------
LLM_API_KEY=                # API key for your LLM provider
LLM_API_BASE=               # Base URL (e.g. https://api.openai.com/v1)
LLM_API_MODEL=              # Orchestrator model (e.g. gpt-4o, Nemotron-3-Super-120b)
LEANSTRAL_API_MODEL=        # Proof synthesis model (e.g. leanstral:119b, gpt-4o)

# --- Brave Search MCP ----------------------------------------
BRAVE_API_KEY=              # Brave Search API key (for web search fallback)

# --- Service URLs --------------------------------------------
# Set these to your deployed service endpoints.
# If running locally:  http://localhost:XXXX
# If deployed behind a reverse proxy:  https://your-host/service-prefix
ORCHESTRATOR_URL=http://localhost:8100
LEAN_ENV_URL=http://localhost:8101
PROOF_SEARCH_URL=http://localhost:8102
RETRIEVAL_URL=http://localhost:8103
TELEMETRY_URL=http://localhost:8104

# --- Logging & tuning ----------------------------------------
LOG_LEVEL=info
BRANCH_BUDGET=50
PROOF_TIMEOUT_SECS=120
